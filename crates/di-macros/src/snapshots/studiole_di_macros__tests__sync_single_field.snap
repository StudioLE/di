impl ::studiole_di::FromProvider for Database {
    type Error = ::studiole_di::ResolveError;
    fn from_provider(
        services: &::studiole_di::ServiceProvider,
    ) -> ::std::result::Result<
        Self,
        ::studiole_report::prelude::Report<::studiole_di::ResolveError>,
    > {
        Ok(Self { config: services.get()? })
    }
}
